--[[
  Returns true if string ends with given string

  Magic characters are quoted.
]]
local ends_with =
  function(base_str, postfix_str)
    local postfix_pattern = quote_regexp(postfix_str) .. '$'

    local start_pos = string.find(base_str, postfix_pattern)

